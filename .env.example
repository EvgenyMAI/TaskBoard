# === Security ===
# JWT secret used by all backend services (use a long random string in production)
JWT_SECRET=taskboard-auth-secret-key-min-256-bits-for-hs256
# Internal key for tasks-service -> analytics-service notifications
NOTIFICATIONS_INTERNAL_KEY=taskboard-internal-key

# === Logging ===
# TRACE | DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# === Service ports (host side) ===
AUTH_SERVICE_PORT=8081
TASKS_SERVICE_PORT=8082
ANALYTICS_SERVICE_PORT=8083
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# === auth-service database ===
POSTGRES_AUTH_DB=taskboard_auth
POSTGRES_AUTH_USER=postgres
POSTGRES_AUTH_PASSWORD=postgres
POSTGRES_AUTH_PORT=5432

# === tasks-service database ===
POSTGRES_TASKS_DB=taskboard_tasks
POSTGRES_TASKS_USER=postgres
POSTGRES_TASKS_PASSWORD=postgres
POSTGRES_TASKS_PORT=5433

# === analytics-service database ===
POSTGRES_ANALYTICS_DB=taskboard_analytics
POSTGRES_ANALYTICS_USER=postgres
POSTGRES_ANALYTICS_PASSWORD=postgres
POSTGRES_ANALYTICS_PORT=5434

# === MinIO object storage (attachments) ===
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=taskboard-attachments
