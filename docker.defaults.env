# Скопируйте в ".env" в корне репозитория или укажите явно:
#   docker compose --env-file docker.defaults.env up -d
# Так порты не зависят от случайных переменных, оставшихся в shell после тестов.
AUTH_SERVICE_PORT=8081
TASKS_SERVICE_PORT=8082
ANALYTICS_SERVICE_PORT=8083
POSTGRES_AUTH_PORT=5432
POSTGRES_TASKS_PORT=5433
POSTGRES_ANALYTICS_PORT=5434
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
