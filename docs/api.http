@authHost = http://localhost:8081
@tasksHost = http://localhost:8082
@analyticsHost = http://localhost:8083
@token = paste_your_jwt_here
@adminToken = paste_admin_jwt_here
@projectId = 1
@taskId = 1
@commentId = 1
@attachmentId = 1
@notificationId = 1
@userId = 1

### Register
POST {{authHost}}/api/auth/register
Content-Type: application/json

{
  "username": "http_user",
  "password": "password123",
  "email": "http_user@example.com"
}

### Login
POST {{authHost}}/api/auth/login
Content-Type: application/json

{
  "username": "http_user",
  "password": "password123"
}

### Validate token
GET {{authHost}}/api/auth/validate
Authorization: Bearer {{token}}

### My profile
GET {{authHost}}/api/auth/me
Authorization: Bearer {{token}}

### Update profile
PUT {{authHost}}/api/auth/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "username": "http_user_updated",
  "email": "http_user_updated@example.com"
}

### Change password
PUT {{authHost}}/api/auth/me/password
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "currentPassword": "password123",
  "newPassword": "password1234",
  "confirmationPhrase": "I_CONFIRM_PASSWORD_CHANGE"
}

### Users list
GET {{authHost}}/api/users
Authorization: Bearer {{token}}

### Update user role (admin only)
PUT {{authHost}}/api/auth/users/{{userId}}/roles
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "roles": ["MANAGER"]
}

### Get projects
GET {{tasksHost}}/api/projects
Authorization: Bearer {{token}}

### Create project
POST {{tasksHost}}/api/projects
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "HTTP Project",
  "description": "Created from api.http"
}

### Get project by id
GET {{tasksHost}}/api/projects/{{projectId}}
Authorization: Bearer {{token}}

### Update project
PUT {{tasksHost}}/api/projects/{{projectId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "HTTP Project Updated",
  "description": "Updated from api.http"
}

### Delete project
DELETE {{tasksHost}}/api/projects/{{projectId}}
Authorization: Bearer {{token}}

### Get project members
GET {{tasksHost}}/api/projects/{{projectId}}/members
Authorization: Bearer {{token}}

### Add project member
POST {{tasksHost}}/api/projects/{{projectId}}/members
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "userId": {{userId}}
}

### Remove project member
DELETE {{tasksHost}}/api/projects/{{projectId}}/members/{{userId}}
Authorization: Bearer {{adminToken}}

### Get tasks with filters
GET {{tasksHost}}/api/tasks?projectId={{projectId}}&status=OPEN&page=0&size=20
Authorization: Bearer {{token}}

### Get tasks filtered by assignee
GET {{tasksHost}}/api/tasks?assigneeId={{userId}}&page=0&size=20
Authorization: Bearer {{token}}

### Create task
POST {{tasksHost}}/api/tasks
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "projectId": {{projectId}},
  "title": "HTTP Task",
  "description": "Task created via api.http",
  "status": "OPEN",
  "assigneeId": {{userId}},
  "dueDate": null
}

### Get task by id
GET {{tasksHost}}/api/tasks/{{taskId}}
Authorization: Bearer {{token}}

### Update task
PUT {{tasksHost}}/api/tasks/{{taskId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "projectId": {{projectId}},
  "title": "HTTP Task Updated",
  "description": "Task updated via api.http",
  "status": "IN_PROGRESS",
  "assigneeId": {{userId}},
  "dueDate": null
}

### Delete task
DELETE {{tasksHost}}/api/tasks/{{taskId}}
Authorization: Bearer {{token}}

### Get comments
GET {{tasksHost}}/api/tasks/{{taskId}}/comments
Authorization: Bearer {{token}}

### Add comment
POST {{tasksHost}}/api/tasks/{{taskId}}/comments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "text": "Comment from api.http"
}

### Delete comment
DELETE {{tasksHost}}/api/tasks/{{taskId}}/comments/{{commentId}}
Authorization: Bearer {{token}}

### Get attachments
GET {{tasksHost}}/api/tasks/{{taskId}}/attachments
Authorization: Bearer {{token}}

### Upload attachment file (multipart)
POST {{tasksHost}}/api/tasks/{{taskId}}/attachments/upload
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="sample.txt"
Content-Type: text/plain

sample content
--WebAppBoundary--

### Download attachment file
GET {{tasksHost}}/api/tasks/{{taskId}}/attachments/{{attachmentId}}/download
Authorization: Bearer {{token}}

### Preview attachment (images/text/pdf)
GET {{tasksHost}}/api/tasks/{{taskId}}/attachments/{{attachmentId}}/preview
Authorization: Bearer {{token}}

### Delete attachment
DELETE {{tasksHost}}/api/tasks/{{taskId}}/attachments/{{attachmentId}}
Authorization: Bearer {{token}}

### Task history
GET {{tasksHost}}/api/tasks/{{taskId}}/history?limit=50
Authorization: Bearer {{token}}

### Notifications list
GET {{analyticsHost}}/api/notifications?read=false&limit=20
Authorization: Bearer {{token}}

### Unread notifications count
GET {{analyticsHost}}/api/notifications/unread
Authorization: Bearer {{token}}

### Mark notification as read
PATCH {{analyticsHost}}/api/notifications/{{notificationId}}/read
Authorization: Bearer {{token}}

### Report summary
GET {{analyticsHost}}/api/reports/summary
Authorization: Bearer {{token}}

### Report summary by period
GET {{analyticsHost}}/api/reports/summary?from=2026-03-01T00:00:00Z&to=2026-03-31T23:59:59Z
Authorization: Bearer {{token}}

### Report by project
GET {{analyticsHost}}/api/reports/by-project?from=2026-03-01T00:00:00Z&to=2026-03-31T23:59:59Z
Authorization: Bearer {{token}}

### Report by assignee
GET {{analyticsHost}}/api/reports/by-assignee?from=2026-03-01T00:00:00Z&to=2026-03-31T23:59:59Z
Authorization: Bearer {{token}}

### Export analytics report (CSV for Excel)
GET {{analyticsHost}}/api/reports/export?from=2026-03-01T00:00:00Z&to=2026-03-31T23:59:59Z
Authorization: Bearer {{token}}
