# Frontend API endpoints (for local Docker setup)
# npm run dev: см. закоммиченный .env.development (порты как в docker-compose по умолчанию).
# Если меняли порты в shell или в .env для compose — скопируйте этот файл в .env.local и поправьте URL.
VITE_AUTH_API=http://localhost:8081/api/auth
VITE_USERS_API=http://localhost:8081/api/users
VITE_TASKS_API=http://localhost:8082/api
VITE_ANALYTICS_API=http://localhost:8083/api
